{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "caption-studio-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-X", "utf8", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "env": { "PYTHONUTF8": "1", "PYTHONIOENCODING": "utf-8" },
      "port": 8000
    }
  ]
}
